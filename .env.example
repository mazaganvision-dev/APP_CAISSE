# Turso (LibSQL) — never commit real values
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN=""

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=""

# Optional: protect cron / internal jobs (Vercel Cron sends this header)
CRON_SECRET=""

# One-time seed (npm run seed) — only needed when creating initial users
# SEED_ADMIN_EMAIL="admin@optique.local"
# SEED_ADMIN_PASSWORD=""
# SEED_WORKER_EMAIL="employe@optique.local"
# SEED_WORKER_PASSWORD=""

# Phase 2 — WhatsApp (Meta Cloud API, Twilio, etc.); leave empty until configured
WHATSAPP_PROVIDER="none"
WHATSAPP_API_URL=""
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
WHATSAPP_TO_E164=""
